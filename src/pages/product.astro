---
import Layout from '../layouts/Layout.astro';

const product = {
  id: 'luma-radiance-serum',
  name: 'Radiance Renewal Serum',
  category: 'Skincare',
  price: 89,
  rating: 4.2,
  reviews: 127,
  description: 'A potent brightening serum powered by 15% Vitamin C, hyaluronic acid, and niacinamide. Clinically proven to visibly improve radiance, even skin tone, and reduce the appearance of dark spots in just 4 weeks.',
  images: [
    'https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?w=800&h=1000&fit=crop&q=80',
    'https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=800&h=1000&fit=crop&q=80',
    'https://images.unsplash.com/photo-1612817288484-6f916006741a?w=800&h=1000&fit=crop&q=80',
    'https://images.unsplash.com/photo-1619451334792-150fd785ee74?w=800&h=1000&fit=crop&q=80',
  ],
};

const related = [
  { id: 'luma-cloud-cream', name: 'Cloud Silk Moisturiser', category: 'Skincare', price: 72, image: 'https://images.unsplash.com/photo-1611930022073-b7a4ba5fcccd?w=600&h=800&fit=crop&q=80' },
  { id: 'luma-petal-cleanser', name: 'Petal Soft Cleanser', category: 'Skincare', price: 54, image: 'https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=600&h=800&fit=crop&q=80' },
  { id: 'luma-mineral-spf', name: 'Mineral Veil SPF 50+', category: 'Skincare', price: 52, image: 'https://images.unsplash.com/photo-1590439471364-192aa70c0b53?w=600&h=800&fit=crop&q=80' },
];

const reviewsList = [
  { author: 'Sarah M.', date: '2 weeks ago', rating: 5, text: 'Absolutely love this serum. My skin looks noticeably brighter after just three weeks. The texture is so lightweight — it absorbs instantly and layers beautifully under makeup.' },
  { author: 'Jessica L.', date: '1 month ago', rating: 4, text: 'Really impressed with the ingredient list and the results. My hyperpigmentation has faded significantly. Only reason for 4 stars is I wish the bottle was larger for the price.' },
  { author: 'Priya K.', date: '1 month ago', rating: 5, text: 'The best Vitamin C serum I\'ve tried. No irritation, no stickiness, just gorgeous glowing skin. The packaging feels so premium too — it makes my whole routine feel special.' },
];
---

<Layout title={`${product.name} — LUMA`} description={product.description}>
  <!-- Breadcrumb -->
  <div class="pt-[72px]">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-5">
      <div class="flex items-center gap-2 text-xs text-luma-warm">
        <a href="/" class="hover:text-luma-black transition-colors">Home</a><span>/</span>
        <a href="/shop" class="hover:text-luma-black transition-colors">Skincare</a><span>/</span>
        <span class="text-luma-black">{product.name}</span>
      </div>
    </div>
  </div>

  <!-- Product Detail -->
  <section class="pb-20">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
        <!-- Gallery -->
        <div class="lg:sticky lg:top-[100px] lg:self-start">
          <div class="aspect-[3/4] overflow-hidden bg-luma-cream mb-3" id="main-image">
            <img src={product.images[0]} alt={product.name} class="w-full h-full object-cover" id="gallery-main" />
          </div>
          <div class="grid grid-cols-4 gap-3">
            {product.images.map((img, i) => (
              <button class={`aspect-square overflow-hidden border-2 transition-colors gallery-thumb ${i === 0 ? 'border-luma-black' : 'border-transparent hover:border-luma-sand'}`} data-img={img}>
                <img src={img} alt={`${product.name} view ${i + 1}`} class="w-full h-full object-cover" loading="lazy" />
              </button>
            ))}
          </div>
        </div>

        <!-- Info -->
        <div class="py-4 lg:py-8">
          <p class="overline mb-3">Luma {product.category}</p>
          <h1 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] font-medium leading-tight">{product.name}</h1>

          <!-- Stars -->
          <div class="flex items-center gap-2 mt-3">
            <div class="flex gap-0.5 text-luma-copper">
              {[1,2,3,4].map(() => <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2.2 4.5 5 .7-3.6 3.5.8 5L8 12.4 3.6 14.7l.8-5L.8 6.2l5-.7z"/></svg>)}
              <svg class="w-3.5 h-3.5 opacity-30" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2.2 4.5 5 .7-3.6 3.5.8 5L8 12.4 3.6 14.7l.8-5L.8 6.2l5-.7z"/></svg>
            </div>
            <span class="text-xs text-luma-warm">({product.reviews} reviews)</span>
          </div>

          <p class="text-2xl font-semibold mt-6 mb-1">${product.price}.00</p>
          <p class="text-luma-charcoal leading-relaxed mt-5">{product.description}</p>

          <!-- Size -->
          <div class="mt-8">
            <p class="text-[0.65rem] font-bold tracking-[0.16em] uppercase mb-3">Size</p>
            <div class="flex gap-3">
              <button class="px-5 py-2.5 border-2 border-luma-black text-xs font-semibold tracking-wider uppercase">30ml</button>
              <button class="px-5 py-2.5 border border-luma-sand text-xs font-medium tracking-wider uppercase text-luma-stone hover:border-luma-black transition-colors">50ml</button>
            </div>
          </div>

          <!-- Quantity -->
          <div class="mt-8">
            <p class="text-[0.65rem] font-bold tracking-[0.16em] uppercase mb-3">Quantity</p>
            <div class="inline-flex items-center border border-luma-sand">
              <button class="w-10 h-10 flex items-center justify-center text-lg hover:bg-luma-cream transition-colors" id="qty-minus">&minus;</button>
              <span class="w-12 text-center text-sm font-medium border-x border-luma-sand py-2.5" id="qty-value">1</span>
              <button class="w-10 h-10 flex items-center justify-center text-lg hover:bg-luma-cream transition-colors" id="qty-plus">&plus;</button>
            </div>
          </div>

          <!-- Add to cart -->
          <div class="flex gap-3 mt-8">
            <button
              class="snipcart-add-item btn-shine flex-1 py-4 bg-luma-black text-white text-[0.7rem] font-semibold tracking-[0.18em] uppercase hover:bg-luma-charcoal hover:-translate-y-0.5 hover:shadow-lg transition-all"
              data-item-id={product.id}
              data-item-price={product.price}
              data-item-url="/product"
              data-item-name={product.name}
              data-item-image={product.images[0]}
              data-item-description={product.description}
            >
              Add to Bag
            </button>
            <button class="w-[52px] h-[52px] border border-luma-sand flex items-center justify-center hover:border-luma-black transition-colors flex-shrink-0" aria-label="Wishlist">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
          </div>

          <!-- Perks -->
          <div class="flex gap-6 mt-6 py-5 border-y border-luma-cream">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-luma-stone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 4v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span class="text-xs text-luma-stone">Free shipping over $75</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-luma-stone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12a9 9 0 0 1 9-9 9 9 0 0 1 9 9 9 9 0 0 1-9 9 9 9 0 0 1-9-9z"/><path d="M12 8v4l3 3"/></svg>
              <span class="text-xs text-luma-stone">30-day returns</span>
            </div>
          </div>

          <!-- Accordion -->
          <div class="mt-6 divide-y divide-luma-cream border-b border-luma-cream">
            <details class="group">
              <summary class="flex items-center justify-between py-4 cursor-pointer text-[0.7rem] font-bold tracking-[0.14em] uppercase">
                Ingredients
                <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="pb-5 text-sm text-luma-charcoal leading-relaxed">
                <p><strong>Key Actives:</strong> 15% Vitamin C (Ascorbic Acid), Hyaluronic Acid, Niacinamide, Ferulic Acid, Vitamin E</p>
                <p class="mt-3"><strong>Full Ingredients:</strong> Aqua, Ascorbic Acid, Propanediol, Glycerin, Niacinamide, Sodium Hyaluronate, Ferulic Acid, Tocopherol, Panthenol, Aloe Barbadensis Leaf Juice, Rosa Damascena Flower Water, Squalane, Phenoxyethanol, Ethylhexylglycerin.</p>
              </div>
            </details>
            <details class="group">
              <summary class="flex items-center justify-between py-4 cursor-pointer text-[0.7rem] font-bold tracking-[0.14em] uppercase">
                How to Use
                <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="pb-5 text-sm text-luma-charcoal leading-relaxed">
                <p>Apply 3–4 drops to clean, dry skin morning and evening. Gently press into face and neck. Follow with your favourite Luma moisturiser. Always follow with SPF for AM use.</p>
              </div>
            </details>
            <details class="group">
              <summary class="flex items-center justify-between py-4 cursor-pointer text-[0.7rem] font-bold tracking-[0.14em] uppercase">
                Shipping & Returns
                <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="pb-5 text-sm text-luma-charcoal leading-relaxed">
                <p>Free standard shipping on orders over $75. Express shipping available at checkout. 30-day return policy on all unopened products.</p>
              </div>
            </details>
          </div>
        </div>
      </div>

      <!-- Reviews -->
      <div class="mt-20 pt-16 border-t border-luma-cream" data-reveal>
        <div class="flex items-start justify-between mb-10">
          <div>
            <h2 class="font-display text-2xl lg:text-3xl font-medium">Customer Reviews</h2>
            <div class="flex items-center gap-2 mt-2">
              <div class="flex gap-0.5 text-luma-copper">
                {[1,2,3,4].map(() => <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2.2 4.5 5 .7-3.6 3.5.8 5L8 12.4 3.6 14.7l.8-5L.8 6.2l5-.7z"/></svg>)}
                <svg class="w-3.5 h-3.5 opacity-30" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2.2 4.5 5 .7-3.6 3.5.8 5L8 12.4 3.6 14.7l.8-5L.8 6.2l5-.7z"/></svg>
              </div>
              <span class="text-xs text-luma-warm">{product.rating} out of 5 ({product.reviews} reviews)</span>
            </div>
          </div>
          <button class="hidden sm:inline-flex px-6 py-3 border border-luma-black text-[0.65rem] font-semibold tracking-[0.14em] uppercase hover:bg-luma-black hover:text-white transition-all">Write a Review</button>
        </div>
        {reviewsList.map(review => (
          <div class="py-6 border-b border-luma-cream">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-sm font-semibold">{review.author}</span>
              <span class="text-xs text-luma-warm">{review.date}</span>
            </div>
            <div class="flex gap-0.5 text-luma-copper mb-2">
              {Array.from({length: review.rating}).map(() => <svg class="w-3 h-3" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l2.2 4.5 5 .7-3.6 3.5.8 5L8 12.4 3.6 14.7l.8-5L.8 6.2l5-.7z"/></svg>)}
            </div>
            <p class="text-sm text-luma-charcoal leading-relaxed">{review.text}</p>
          </div>
        ))}
      </div>

      <!-- Related -->
      <div class="mt-20 pt-16 border-t border-luma-cream" data-reveal>
        <div class="text-center mb-12">
          <p class="overline mb-3">Complete Your Ritual</p>
          <h2 class="font-display text-2xl lg:text-3xl font-medium">You May Also Like</h2>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-x-5 gap-y-10">
          {related.map(item => (
            <div class="group">
              <a href="/product" class="block aspect-[3/4] overflow-hidden bg-luma-cream mb-4 img-zoom">
                <img src={item.image} alt={item.name} class="w-full h-full object-cover" loading="lazy" />
              </a>
              <p class="text-[0.6rem] font-semibold tracking-[0.18em] uppercase text-luma-warm mb-1">Luma {item.category}</p>
              <h3 class="font-display text-lg font-medium"><a href="/product" class="hover:text-luma-copper transition-colors">{item.name}</a></h3>
              <p class="text-sm font-semibold text-luma-charcoal mt-1">${item.price}.00</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    // Gallery thumbnails
    document.querySelectorAll('.gallery-thumb').forEach(thumb => {
      thumb.addEventListener('click', () => {
        document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.replace('border-luma-black', 'border-transparent'));
        thumb.classList.replace('border-transparent', 'border-luma-black');
        document.getElementById('gallery-main').src = thumb.dataset.img;
      });
    });
    // Quantity
    let qty = 1;
    document.getElementById('qty-minus')?.addEventListener('click', () => { if (qty > 1) document.getElementById('qty-value').textContent = --qty; });
    document.getElementById('qty-plus')?.addEventListener('click', () => { if (qty < 10) document.getElementById('qty-value').textContent = ++qty; });
  </script>
</Layout>
