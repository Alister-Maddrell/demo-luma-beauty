---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Luxury skincare & beauty crafted with intention. Clean formulas, elevated rituals, radiant results." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.css">
  <style>
    @import '../styles/global.css';
  </style>
</head>
<body class="min-h-screen overflow-x-hidden">
  <!-- Header -->
  <header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background: rgba(254,253,251,0.9); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="flex items-center justify-between h-[72px]">
        <!-- Logo -->
        <a href="/" class="text-[1.6rem] font-light tracking-[0.22em] uppercase text-luma-black hover:opacity-70 transition-opacity">
          Luma
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-10" aria-label="Main navigation">
          <a href="/shop" class="text-[0.7rem] font-semibold tracking-[0.16em] uppercase text-luma-charcoal hover:text-luma-copper transition-colors relative group">
            Shop
            <span class="absolute -bottom-1 left-0 w-0 h-px bg-luma-copper transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/about" class="text-[0.7rem] font-semibold tracking-[0.16em] uppercase text-luma-charcoal hover:text-luma-copper transition-colors relative group">
            Our Story
            <span class="absolute -bottom-1 left-0 w-0 h-px bg-luma-copper transition-all duration-300 group-hover:w-full"></span>
          </a>
        </nav>

        <!-- Actions -->
        <div class="flex items-center gap-5">
          <button aria-label="Search" class="w-10 h-10 flex items-center justify-center hover:opacity-60 transition-opacity">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
          <button aria-label="Account" class="w-10 h-10 hidden sm:flex items-center justify-center hover:opacity-60 transition-opacity">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M5 20c0-4 3.5-7 7-7s7 3 7 7"/></svg>
          </button>
          <button class="snipcart-checkout w-10 h-10 flex items-center justify-center hover:opacity-60 transition-opacity relative" aria-label="Shopping bag">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="snipcart-items-count absolute -top-0.5 -right-0.5 w-4 h-4 bg-luma-copper text-white text-[9px] font-bold rounded-full flex items-center justify-center"></span>
          </button>
          <!-- Mobile menu -->
          <button id="menu-toggle" class="lg:hidden w-10 h-10 flex flex-col items-center justify-center gap-[5px] p-2" aria-label="Menu" aria-expanded="false">
            <span class="w-full h-px bg-luma-black transition-all duration-300 origin-center" id="line1"></span>
            <span class="w-full h-px bg-luma-black transition-all duration-300" id="line2"></span>
            <span class="w-full h-px bg-luma-black transition-all duration-300 origin-center" id="line3"></span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Mobile Nav -->
  <div id="mobile-nav" class="fixed inset-0 z-40 bg-luma-white pt-[72px] px-6 translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] lg:hidden">
    <nav class="flex flex-col gap-0 pt-8">
      <a href="/" class="text-[2rem] font-light tracking-wide py-3 border-b border-luma-cream hover:text-luma-copper transition-colors">Home</a>
      <a href="/shop" class="text-[2rem] font-light tracking-wide py-3 border-b border-luma-cream hover:text-luma-copper transition-colors">Shop</a>
      <a href="/about" class="text-[2rem] font-light tracking-wide py-3 border-b border-luma-cream hover:text-luma-copper transition-colors">Our Story</a>
    </nav>
  </div>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-luma-sand/30 pt-20 pb-10">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-10 lg:gap-16 mb-16">
        <!-- Brand -->
        <div class="col-span-2 md:col-span-4 lg:col-span-2">
          <a href="/" class="text-xl font-light tracking-[0.22em] uppercase inline-block mb-5">Luma</a>
          <p class="text-sm text-luma-stone leading-relaxed max-w-xs mb-6">Luxury beauty crafted with intention. Clean formulas for the modern woman who values quality over quantity.</p>
          <div class="flex gap-4">
            <a href="#" class="w-9 h-9 border border-luma-sand/50 flex items-center justify-center hover:bg-luma-black hover:border-luma-black hover:text-white transition-all" aria-label="Instagram">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="#" class="w-9 h-9 border border-luma-sand/50 flex items-center justify-center hover:bg-luma-black hover:border-luma-black hover:text-white transition-all" aria-label="TikTok">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
            </a>
            <a href="#" class="w-9 h-9 border border-luma-sand/50 flex items-center justify-center hover:bg-luma-black hover:border-luma-black hover:text-white transition-all" aria-label="Pinterest">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 21c1-4 2-7 3-9s2-4 4-4 2 2 1 4-3 5-3 7"/></svg>
            </a>
          </div>
        </div>
        <div>
          <h4 class="text-[0.65rem] font-bold tracking-[0.2em] uppercase mb-5">Shop</h4>
          <div class="flex flex-col gap-2.5">
            <a href="/shop" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Skincare</a>
            <a href="/shop" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Makeup</a>
            <a href="/shop" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Body</a>
            <a href="/shop" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Gift Sets</a>
            <a href="/shop" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Bestsellers</a>
          </div>
        </div>
        <div>
          <h4 class="text-[0.65rem] font-bold tracking-[0.2em] uppercase mb-5">About</h4>
          <div class="flex flex-col gap-2.5">
            <a href="/about" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Our Story</a>
            <a href="#" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Ingredients</a>
            <a href="#" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Sustainability</a>
            <a href="#" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Press</a>
          </div>
        </div>
        <div>
          <h4 class="text-[0.65rem] font-bold tracking-[0.2em] uppercase mb-5">Help</h4>
          <div class="flex flex-col gap-2.5">
            <a href="#" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Contact Us</a>
            <a href="#" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Shipping & Returns</a>
            <a href="#" class="text-sm text-luma-stone hover:text-luma-black transition-colors">FAQs</a>
            <a href="#" class="text-sm text-luma-stone hover:text-luma-black transition-colors">Track Order</a>
          </div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-luma-sand/30">
        <p class="text-xs text-luma-warm">&copy; 2026 Luma Beauty. All rights reserved.</p>
        <div class="flex gap-6">
          <a href="#" class="text-xs text-luma-warm hover:text-luma-black transition-colors">Privacy Policy</a>
          <a href="#" class="text-xs text-luma-warm hover:text-luma-black transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Snipcart -->
  <div hidden id="snipcart" data-api-key="YOUR_SNIPCART_API_KEY" data-config-modal-style="side"></div>
  <script is:inline src="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.js"></script>

  <script is:inline>
    // Header scroll
    const header = document.getElementById('header');
    window.addEventListener('scroll', () => {
      header.style.boxShadow = window.scrollY > 50 ? '0 1px 20px rgba(17,17,16,0.04)' : 'none';
    }, { passive: true });

    // Mobile menu
    const toggle = document.getElementById('menu-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');
    let isOpen = false;
    toggle.addEventListener('click', () => {
      isOpen = !isOpen;
      mobileNav.style.transform = isOpen ? 'translateX(0)' : 'translateX(100%)';
      document.body.style.overflow = isOpen ? 'hidden' : '';
      toggle.setAttribute('aria-expanded', isOpen);
      line1.style.transform = isOpen ? 'rotate(45deg) translate(3px, 3px)' : '';
      line2.style.opacity = isOpen ? '0' : '1';
      line3.style.transform = isOpen ? 'rotate(-45deg) translate(3px, -3px)' : '';
    });

    // Scroll reveal
    const reveals = document.querySelectorAll('[data-reveal]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    reveals.forEach(el => observer.observe(el));
  </script>
</body>
</html>
